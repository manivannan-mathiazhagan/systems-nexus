r_lib_version <- paste0(
R.version$major, ".",
strsplit(R.version$minor, "\\.")[[1]][1]
)
setup_packages <- function(required_packages,
lib_path = NULL,
repos = "https://cran.rstudio.com") {
r_lib_version <- paste0(
R.version$major, ".",
strsplit(R.version$minor, "\\.")[[1]][1]
)
if (is.null(lib_path)) {
lib_path <- file.path(
Sys.getenv("USERPROFILE"),
"Documents",
"R",
"win-library",
r_lib_version
)
}
dir.create(lib_path, recursive = TRUE, showWarnings = FALSE)
.libPaths(unique(c(lib_path, .libPaths())))
message("R package library: ", normalizePath(lib_path, winslash = "/", mustWork = FALSE))
for (pkg in required_packages) {
if (!requireNamespace(pkg, quietly = TRUE)) {
message("Installing missing package: ", pkg)
install.packages(
pkg,
lib = lib_path,
repos = repos,
dependencies = TRUE
)
}
suppressPackageStartupMessages(
library(pkg, character.only = TRUE, lib.loc = lib_path)
)
message("Loaded package: ", pkg)
}
invisible(TRUE)
}
message("global_setup.R loaded successfully.")
# =============================================================================
# File    : global_setup.R
# Purpose : Global R setup utility
#           - Package install/load
#           - WORK folder setup
#           - Study library setup
#           - Load reusable functions
# =============================================================================
# -----------------------------------------------------------------------------
# 1. Package setup
# -----------------------------------------------------------------------------
setup_packages <- function(required_packages,
lib_path = NULL,
repos = "https://cran.rstudio.com") {
r_lib_version <- paste0(
R.version$major, ".",
strsplit(R.version$minor, "\\.")[[1]][1]
)
if (is.null(lib_path)) {
lib_path <- file.path(
Sys.getenv("USERPROFILE"),
"Documents",
"R",
"win-library",
r_lib_version
)
}
dir.create(lib_path, recursive = TRUE, showWarnings = FALSE)
.libPaths(unique(c(lib_path, .libPaths())))
message("R package library: ", normalizePath(lib_path, winslash = "/", mustWork = FALSE))
for (pkg in required_packages) {
if (!requireNamespace(pkg, quietly = TRUE)) {
message("Installing missing package: ", pkg)
install.packages(
pkg,
lib = lib_path,
repos = repos,
dependencies = TRUE
)
}
suppressPackageStartupMessages(
library(pkg, character.only = TRUE, lib.loc = lib_path)
)
message("Loaded package: ", pkg)
}
invisible(TRUE)
}
# -----------------------------------------------------------------------------
# 2. WORK folder setup
# -----------------------------------------------------------------------------
setup_work <- function(work_base = tempdir(),
clean_existing = FALSE) {
work_dir <- file.path(work_base, paste0("R_WORK_", Sys.getpid()))
if (clean_existing && dir.exists(work_dir)) {
unlink(work_dir, recursive = TRUE, force = TRUE)
}
dir.create(work_dir, recursive = TRUE, showWarnings = FALSE)
assign("WORK_DIR", normalizePath(work_dir, winslash = "/", mustWork = FALSE), envir = .GlobalEnv)
options(R_WORK_DIR = WORK_DIR)
message("R WORK folder: ", WORK_DIR)
invisible(WORK_DIR)
}
# -----------------------------------------------------------------------------
# 3. Study library setup
#    Similar to SAS LIBNAME concept
# -----------------------------------------------------------------------------
setup_libraries <- function(raw = NULL,
sdtm = NULL,
adam = NULL,
tlf = NULL,
specs = NULL,
output = NULL,
logs = NULL,
extra = list(),
create_missing = FALSE) {
libs <- list(
RAW    = raw,
SDTM   = sdtm,
ADAM   = adam,
TLF    = tlf,
SPECS  = specs,
OUTPUT = output,
LOGS   = logs
)
if (length(extra) > 0) {
libs <- c(libs, extra)
}
libs <- libs[!sapply(libs, is.null)]
if (length(libs) == 0) {
warning("No libraries were provided.")
return(invisible(list()))
}
for (nm in names(libs)) {
path <- normalizePath(libs[[nm]], winslash = "/", mustWork = FALSE)
if (!dir.exists(path)) {
msg <- paste0("Library path does not exist: ", nm, " = ", path)
if (create_missing) {
dir.create(path, recursive = TRUE, showWarnings = FALSE)
message("Created library path: ", nm, " = ", path)
} else {
warning(msg)
}
}
assign(nm, path, envir = .GlobalEnv)
message(nm, " = ", path)
}
invisible(libs)
}
# -----------------------------------------------------------------------------
# 4. Load all reusable function files
# -----------------------------------------------------------------------------
load_all_functions <- function(functions_path) {
functions_path <- normalizePath(functions_path, winslash = "/", mustWork = FALSE)
if (!dir.exists(functions_path)) {
warning("Functions folder not found: ", functions_path)
return(invisible(FALSE))
}
files <- list.files(
functions_path,
pattern = "\\.R$",
full.names = TRUE
)
if (length(files) == 0) {
message("No function files found in: ", functions_path)
return(invisible(FALSE))
}
for (f in files) {
source(f)
message("Loaded function file: ", basename(f))
}
invisible(TRUE)
}
# -----------------------------------------------------------------------------
# 5. Common helper functions
# -----------------------------------------------------------------------------
read_sas_data <- function(lib, dataset) {
file_path <- file.path(lib, paste0(dataset, ".sas7bdat"))
if (!file.exists(file_path)) {
stop("Dataset not found: ", file_path)
}
haven::read_sas(file_path)
}
write_xpt_data <- function(data, out_path) {
out_dir <- dirname(out_path)
dir.create(out_dir, recursive = TRUE, showWarnings = FALSE)
haven::write_xpt(data, out_path)
message("XPT written: ", normalizePath(out_path, winslash = "/", mustWork = FALSE))
invisible(TRUE)
}
write_excel_data <- function(data, out_path, sheet_name = "Sheet1") {
out_dir <- dirname(out_path)
dir.create(out_dir, recursive = TRUE, showWarnings = FALSE)
openxlsx::write.xlsx(
data,
file = out_path,
sheetName = sheet_name,
overwrite = TRUE
)
message("Excel written: ", normalizePath(out_path, winslash = "/", mustWork = FALSE))
invisible(TRUE)
}
# -----------------------------------------------------------------------------
# 6. Startup message
# -----------------------------------------------------------------------------
message("global_setup.R loaded successfully.")
install.packages("readxl")
install.packages("readxl")
