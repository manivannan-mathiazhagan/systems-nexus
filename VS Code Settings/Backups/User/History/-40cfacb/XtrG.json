{
    "workbench.iconTheme": "vscode-icons",
    "window.commandCenter": true,
    // ==== Security ====
    "security.workspace.trust.startupPrompt": "always",
    "security.workspace.trust.enabled": false,
    // ==== Font: Courier New everywhere ====
    "editor.fontFamily": "Courier New, Menlo, monospace",
    "editor.fontSize": 14,
    "terminal.integrated.fontFamily": "Courier New, Menlo, monospace",
    "debug.console.fontFamily": "Courier New, Menlo, monospace",
    // ==== Editor — indentation & formatting ====
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.trimAutoWhitespace": true,
    "editor.renderWhitespace": "boundary",
    "editor.rulers": [
        100
    ],
    "editor.guides.indentation": true,
    "editor.bracketPairColorization.enabled": true,
    // Language overrides
    "[plaintext]": {
        "editor.tabSize": 4
    },
    "[json]": {
        "editor.tabSize": 2,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[sas]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.formatOnSave": true
    },
    // File associations
    "files.associations": {
        "*.sas": "sas"
    },
    // ==== Git ====
    "git.useEditorAsCommitInput": false,
    "git.editor": "code --wait",
    "git.autofetch": true,
    "git.openRepositoryInParentFolders": "always",
    "git.enableSmartCommit": true,
    // ==== Updates ====
    "update.mode": "start",
    "update.showReleaseNotes": true,
    "extensions.autoCheckUpdates": true,
    "extensions.autoUpdate": true,
    // ==== Official SAS extension ====
    "SAS.connectionProfiles": {
        "activeProfile": "escape",
        "profiles": {
            "escape": {
                "name": "escape",
                "serverType": "SAS9",
                "host": "your-sas-host",
                "port": 8591,
                "contextPath": "/",
                "protocol": "http",
                "user": "yourid",
                "connectionType": "rest"
            }
        }
    },
    // ==== SASjs ====
    "sasjs.defaultTarget": "local",
    "sasjs.targets": {
        "local": {
            "serverUrl": "http://localhost",
            "appLoc": "/Public/app",
            "contextName": "SAS Job Execution"
        }
    },
    // ==== Multi Command Macros ====
    "multiCommand.commands": [
        {
            "command": "multiCommand.copyToTop",
            "sequence": [
                "cursorHome", // go to start of current line
                "cursorTopSelect", // select from here to top
                "editor.action.clipboardCopyAction"
            ]
        },
        {
            "command": "multiCommand.sasBlockCommentLine",
            "sequence": [
                "expandLineSelection",
                "cursorLeftSelect", // trims the newline so */ stays on same line
                "editor.action.blockComment"
            ]
        }
    ]
}