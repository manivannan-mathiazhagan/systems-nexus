{
  // ==== Look & feel ====
  "workbench.colorTheme": "SAS Theme",
  "workbench.iconTheme": "vscode-icons",
  "window.commandCenter": true,

  // ==== Security (your earlier prefs) ====
  "security.workspace.trust.startupPrompt": "always",
  "security.workspace.trust.enabled": false,

  // ==== Editor — indentation & formatting ====
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.trimAutoWhitespace": true,
  "editor.renderWhitespace": "boundary",
  "editor.rulers": [100],
  "editor.guides.indentation": true,
  "editor.bracketPairColorization.enabled": true,

  // Language overrides
  "[plaintext]": {
    "editor.tabSize": 2
  },
  "[json]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[sas]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.defaultFormatter": "sassoftware.sas-lsp",
    "editor.formatOnSave": true
  },
  "files.associations": {
    "*.sas": "sas"
  },

  // ==== Git ====
  "git.useEditorAsCommitInput": false,
  "git.editor": "code --wait",
  "git.autofetch": true,
  "git.openRepositoryInParentFolders": "always",
  "git.enableSmartCommit": true,

  // ==== Macros (your copyToTop) ====
  "macros": {
    "copyToTop": [
      "cursorHome",
      "cursorUpSelect",
      {
        "command": "cursorTop",
        "args": { "to": "anchor" }
      },
      "editor.action.clipboardCopyAction"
    ]
  },

  // ==== Updates — surface the update UI/button ====
  "update.mode": "start",
  "update.showReleaseNotes": true,
  "extensions.autoCheckUpdates": true,
  "extensions.autoUpdate": true,

  // ==== Official SAS extension (formatter / connection scaffold) ====
  "SAS.connectionProfiles": {
    "activeProfile": "escape",
    "profiles": {
      "escape": {
        "name": "escape",
        "serverType": "SAS9",
        "host": "your-sas-host",
        "port": 8591,
        "contextPath": "/",
        "protocol": "http",
        "user": "yourid"
      }
    }
  },

  // ==== SASjs (DevOps for SAS) basics ====
  "sasjs.defaultTarget": "local",
  "sasjs.targets": {
    "local": {
      "serverUrl": "http://localhost",
      "appLoc": "/Public/app",
      "contextName": "SAS Job Execution"
    }
  }
}
