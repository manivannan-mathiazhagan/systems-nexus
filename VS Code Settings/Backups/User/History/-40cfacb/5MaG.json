{
    // ==== Look & feel ====
    "workbench.colorTheme": "SAS Light",
    "workbench.iconTheme": "vscode-icons",
    "window.commandCenter": true,

    // ==== Security ====
    "security.workspace.trust.startupPrompt": "always",
    "security.workspace.trust.enabled": false,

    // ==== Font: monospace everywhere ====
    "editor.fontFamily": "'SAS Monospace', 'Courier New', monospace",
    "editor.fontSize": 14,
    "terminal.integrated.fontFamily": "'SAS Monospace', 'Courier New', monospace",
    "debug.console.fontFamily": "'SAS Monospace', 'Courier New', monospace",

    // ==== Editor — indentation & formatting ====
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "editor.trimAutoWhitespace": true,
    "editor.renderWhitespace": "boundary",
    "editor.rulers": [100],
    "editor.guides.indentation": true,
    "editor.bracketPairColorization.enabled": true,

    // Language overrides
    "[plaintext]": {
        "editor.tabSize": 4
    },
    "[json]": {
        "editor.tabSize": 2,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[sas]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.formatOnSave": false
    },

    // File associations
    "files.associations": {
        "*.sas": "sas"
    },

    // ==== Git ====
    "git.useEditorAsCommitInput": false,
    "git.editor": "code --wait",
    "git.autofetch": true,
    "git.openRepositoryInParentFolders": "always",
    "git.enableSmartCommit": true,

    // ==== Updates ====
    "update.mode": "start",
    "update.showReleaseNotes": true,
    "extensions.autoCheckUpdates": true,
    "extensions.autoUpdate": true,

    // ==== Multi Command Macros ====
    "multiCommand.commands": [
        {
            "command": "multiCommand.copyToTop",
            "sequence": ["cursorTopSelect", "editor.action.clipboardCopyAction"]
        },
        {
            "command": "multiCommand.sasBlockCommentLine",
            "sequence": ["expandLineSelection", "cursorLeftSelect", "editor.action.blockComment"]
        }
    ],

    // ==== SAS connection profile (local SAS 9.4 via COM) ====
    "SAS.connectionProfiles": {
        "activeProfile": "sas9-local",
        "profiles": {
            "sas9-local": {
                "connectionType": "com",
                "host": "localhost",
                "interopLibraryFolderPath": "C:\\Program Files\\SASHome\\x86\\Integration Technologies"
            }
        }
    }
}
